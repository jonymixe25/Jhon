{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "contacts": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "integer" }
      },
      "required": ["email", "displayName"]
    },
    "Post": {
      "title": "Post",
      "description": "A photo or video post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["authorId", "mediaUrl", "mediaType", "tags", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["authorId", "text", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "A chat or call room.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "integer" },
        "activeCall": { "type": "boolean" }
      },
      "required": ["type", "members", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat room.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["authorId", "text", "createdAt"]
    },
    "CallSignal": {
      "title": "CallSignal",
      "description": "WebRTC WebRTC signaling.",
      "type": "object",
      "properties": {
        "sdp": { "type": "string" },
        "type": { "type": "string" },
        "callerId": { "type": "string" }
      }
    },
    "IceCandidate": {
      "title": "IceCandidate",
      "description": "WebRTC ICE Candidate.",
      "type": "object",
      "properties": {
        "candidate": { "type": "string" },
        "sdpMid": { "type": "string" },
        "sdpMLineIndex": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile documents"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Post documents"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a post"
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Chat/Video Call Rooms"
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages inside a room"
    },
    "/rooms/{roomId}/signals/{signalId}": {
      "schema": { "$ref": "#/entities/CallSignal" },
      "description": "WebRTC Signals (offers/answers)"
    },
    "/rooms/{roomId}/candidates/{candidateId}": {
      "schema": { "$ref": "#/entities/IceCandidate" },
      "description": "WebRTC ICE Candidates"
    }
  }
}
